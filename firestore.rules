rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    match /{document=**} {
      allow read, write: if false;
    }

    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    function incoming() { return request.resource.data; }
    function existing() { return resource.data; }
    function isSignedIn() { return request.auth != null; }
    function isVerifiedEmail() { return isSignedIn() && request.auth.token.email_verified == true; }

    function isValidUserCreate(data) {
      return data.keys().hasAll(['email', 'createdAt'])
        && data.keys().size() == 2
        && data.email is string && data.email.size() <= 200
        && data.createdAt == request.time;
    }

    match /users/{userId} {
      allow get: if isSignedIn() && request.auth.uid == userId;
      // Allow list with condition just in case, though usually shouldn't list users
      allow list: if isSignedIn() && request.auth.uid == userId;
      
      allow create: if isSignedIn() 
        && request.auth.uid == userId 
        && isValidId(userId)
        && isValidUserCreate(incoming());
        
      allow update: if isSignedIn()
        && request.auth.uid == userId
        && incoming().diff(existing()).affectedKeys().hasOnly(['email'])
        && incoming().email is string && incoming().email.size() <= 200;
        
      allow delete: if false;
    }

    function isValidJovem(data) {
      return data.userId is string && data.userId.size() <= 128
        && data.nome is string && data.nome.size() <= 200
        && data.idade is number
        && (!("dataNascimento" in data) || data.dataNascimento == null || (data.dataNascimento is string && data.dataNascimento.size() <= 50))
        && (!("tamanhoChinelo" in data) || data.tamanhoChinelo == null || (data.tamanhoChinelo is string && data.tamanhoChinelo.size() <= 50))
        && (!("tamanhoRoupa" in data) || data.tamanhoRoupa == null || (data.tamanhoRoupa is string && data.tamanhoRoupa.size() <= 50))
        && (!("telefone" in data) || data.telefone == null || (data.telefone is string && data.telefone.size() <= 50))
        && (!("fotoUrl" in data) || data.fotoUrl == null || (data.fotoUrl is string && data.fotoUrl.size() <= 1048487))
        && data.score is string && (data.score == 'verde' || data.score == 'amarelo' || data.score == 'vermelho')
        && (!("novoConvertido" in data) || data.novoConvertido == null || data.novoConvertido is bool)
        && (!("jornada" in data) || data.jornada == null || (data.jornada is map))
        && (!("ultimaPresenca" in data) || data.ultimaPresenca == null || (data.ultimaPresenca is string && data.ultimaPresenca.size() <= 50))
        && data.dataCadastro is string && data.dataCadastro.size() <= 50
        && data.historicoPresenca is list && data.historicoPresenca.size() <= 1000;
    }

    function isValidJovemCreate(data) {
      return data.keys().hasAll(['userId', 'nome', 'idade', 'score', 'dataCadastro', 'historicoPresenca', 'createdAt'])
        && data.userId == request.auth.uid
        && isValidJovem(data)
        && data.createdAt == request.time;
    }

    match /jovens/{jovemId} {
      allow get: if isSignedIn() && existing().userId == request.auth.uid;
      allow list: if isSignedIn() && resource.data.userId == request.auth.uid;
      
      allow create: if isSignedIn()
        && isValidId(jovemId)
        && isValidJovemCreate(incoming());
        
      allow update: if isSignedIn()
        && existing().userId == request.auth.uid
        && incoming().userId == existing().userId
        && incoming().createdAt == existing().createdAt
        && (incoming().updatedAt == request.time || !("updatedAt" in incoming()))
        && isValidJovem(incoming())
        && (
            incoming().diff(existing()).affectedKeys().hasOnly(['nome', 'idade', 'dataNascimento', 'tamanhoChinelo', 'tamanhoRoupa', 'telefone', 'fotoUrl', 'score', 'novoConvertido', 'ultimaPresenca', 'historicoPresenca', 'jornada', 'updatedAt'])
        );
        
      allow delete: if isSignedIn() && existing().userId == request.auth.uid;
    }

    function isValidEvento(data) {
      return data.userId is string && data.userId.size() <= 128
        && data.nome is string && data.nome.size() <= 200
        && data.data is string && data.data.size() <= 50
        && data.realizado is bool;
    }

    function isValidEventoCreate(data) {
      return data.keys().hasAll(['userId', 'nome', 'data', 'realizado', 'createdAt'])
        && data.keys().size() <= 6
        && data.userId == request.auth.uid
        && isValidEvento(data)
        && data.createdAt == request.time;
    }

    match /eventos/{eventoId} {
      allow get: if isSignedIn() && existing().userId == request.auth.uid;
      allow list: if isSignedIn() && resource.data.userId == request.auth.uid;
      
      allow create: if isSignedIn()
        && isValidId(eventoId)
        && isValidEventoCreate(incoming());
        
      allow update: if isSignedIn()
        && existing().userId == request.auth.uid
        && incoming().userId == existing().userId
        && incoming().createdAt == existing().createdAt
        && (incoming().updatedAt == request.time || !("updatedAt" in incoming()))
        && isValidEvento(incoming())
        && (
            incoming().diff(existing()).affectedKeys().hasOnly(['nome', 'data', 'realizado', 'updatedAt'])
        );
        
      allow delete: if isSignedIn() && existing().userId == request.auth.uid;
    }

    function isValidMaterial(data) {
      return data.userId is string && data.userId.size() <= 128
        && data.titulo is string && data.titulo.size() <= 200
        && data.descricao is string && data.descricao.size() <= 2000
        && data.tipo is string && (data.tipo == 'pdf' || data.tipo == 'video' || data.tipo == 'artigo' || data.tipo == 'podcast')
        && data.link is string && data.link.size() <= 500
        && data.dataPublicacao is string && data.dataPublicacao.size() <= 30;
    }

    function isValidMaterialCreate(data) {
      return data.keys().hasAll(['userId', 'titulo', 'descricao', 'tipo', 'link', 'dataPublicacao', 'createdAt'])
        && data.keys().size() <= 8
        && data.userId == request.auth.uid
        && isValidMaterial(data)
        && data.createdAt == request.time;
    }

    match /materiais/{materialId} {
      allow get: if isSignedIn() && existing().userId == request.auth.uid;
      allow list: if isSignedIn() && resource.data.userId == request.auth.uid;
      
      allow create: if isSignedIn()
        && isValidId(materialId)
        && isValidMaterialCreate(incoming());
        
      allow update: if isSignedIn()
        && existing().userId == request.auth.uid
        && incoming().userId == existing().userId
        && incoming().createdAt == existing().createdAt
        && isValidMaterial(incoming())
        && (
            incoming().diff(existing()).affectedKeys().hasOnly(['titulo', 'descricao', 'tipo', 'link', 'dataPublicacao', 'updatedAt'])
        );
        
      allow delete: if isSignedIn() && existing().userId == request.auth.uid;
    }

    function isValidDiretoria(data) {
      return data.userId is string && data.userId.size() <= 128
        && data.nome is string && data.nome.size() <= 200
        && data.cargo is string && data.cargo.size() <= 200
        && (!("fotoUrl" in data) || data.fotoUrl == null || (data.fotoUrl is string && data.fotoUrl.size() <= 1048487));
    }

    function isValidDiretoriaCreate(data) {
      return data.keys().hasAll(['userId', 'nome', 'cargo', 'createdAt'])
        && data.userId == request.auth.uid
        && isValidDiretoria(data)
        && data.createdAt == request.time;
    }

    match /diretoria/{membroId} {
      allow get: if isSignedIn() && existing().userId == request.auth.uid;
      allow list: if isSignedIn() && resource.data.userId == request.auth.uid;
      
      allow create: if isSignedIn()
        && isValidId(membroId)
        && isValidDiretoriaCreate(incoming());
        
      allow update: if isSignedIn()
        && existing().userId == request.auth.uid
        && incoming().userId == existing().userId
        && incoming().createdAt == existing().createdAt
        && isValidDiretoria(incoming())
        && (
            incoming().diff(existing()).affectedKeys().hasOnly(['nome', 'cargo', 'fotoUrl'])
        );
        
      allow delete: if isSignedIn() && existing().userId == request.auth.uid;
    }

    function isValidIgreja(data) {
      return data.userId is string && data.userId.size() <= 128
        && data.nome is string && data.nome.size() <= 200
        && data.endereco is string && data.endereco.size() <= 500
        && data.telefone is string && data.telefone.size() <= 50
        && data.instagram is string && data.instagram.size() <= 100
        && (!("logoUrl" in data) || data.logoUrl == null || (data.logoUrl is string && data.logoUrl.size() <= 1048487));
    }

    function isValidIgrejaCreate(data) {
      return data.keys().hasAll(['userId', 'nome', 'endereco', 'telefone', 'instagram', 'createdAt', 'updatedAt'])
        && data.userId == request.auth.uid
        && isValidIgreja(data)
        && data.createdAt == request.time
        && data.updatedAt == request.time;
    }

    match /igrejas/{igrejaId} {
      allow get: if isSignedIn() && existing().userId == request.auth.uid;
      allow list: if isSignedIn() && resource.data.userId == request.auth.uid;
      
      allow create: if isSignedIn()
        && isValidId(igrejaId)
        && isValidIgrejaCreate(incoming());
        
      allow update: if isSignedIn()
        && existing().userId == request.auth.uid
        && incoming().userId == existing().userId
        && incoming().createdAt == existing().createdAt
        && incoming().updatedAt == request.time
        && isValidIgreja(incoming())
        && (
            incoming().diff(existing()).affectedKeys().hasOnly(['nome', 'endereco', 'telefone', 'instagram', 'logoUrl', 'updatedAt'])
        );
        
      allow delete: if false;
    }

    function isValidTransacao(data) {
      return data.userId is string && data.userId.size() <= 128
        && data.descricao is string && data.descricao.size() <= 200
        && data.valor is number
        && data.tipo is string && (data.tipo == 'entrada' || data.tipo == 'saida')
        && data.data is string && data.data.size() <= 50
        && (!("categoria" in data) || data.categoria == null || (data.categoria is string && data.categoria.size() <= 100));
    }

    function isValidTransacaoCreate(data) {
      return data.keys().hasAll(['userId', 'descricao', 'valor', 'tipo', 'data', 'createdAt'])
        && data.userId == request.auth.uid
        && isValidTransacao(data)
        && data.createdAt == request.time;
    }

    match /transacoes/{transacaoId} {
      allow get: if isSignedIn() && existing().userId == request.auth.uid;
      allow list: if isSignedIn() && resource.data.userId == request.auth.uid;
      
      allow create: if isSignedIn()
        && isValidId(transacaoId)
        && isValidTransacaoCreate(incoming());
        
      allow update: if isSignedIn()
        && existing().userId == request.auth.uid
        && incoming().userId == existing().userId
        && incoming().createdAt == existing().createdAt
        && (incoming().updatedAt == request.time || !("updatedAt" in incoming()))
        && isValidTransacao(incoming())
        && (
            incoming().diff(existing()).affectedKeys().hasOnly(['descricao', 'valor', 'tipo', 'data', 'categoria', 'updatedAt'])
        );
        
      allow delete: if isSignedIn() && existing().userId == request.auth.uid;
    }
  }
}
